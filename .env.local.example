# ============================================================
# Notion API 設定 — このファイルを .env.local にコピーして設定する
# .env.local は .gitignore に追加済みなので Git にはコミットされない
# ============================================================

# Notion インテグレーショントークン
# 取得方法: https://www.notion.so/my-integrations → 「新しいインテグレーション」
NOTION_TOKEN=secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Notion データベース ID
# 取得方法: ブログDBページのURLから取得 (末尾の 32文字)
# 例: https://notion.so/YOUR_WORKSPACE/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX?v=...
NOTION_DB_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
